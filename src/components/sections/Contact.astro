---
---

<section id="contact" class="py-24 bg-slate-950 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_100%,rgba(99,102,241,0.08),transparent)]"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Left: text -->
      <div class="lg:pt-4">
        <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-6">
          <span class="text-slate-400 text-sm font-medium">Безкоштовне демо</span>
        </div>
        <h2 class="text-4xl sm:text-5xl font-extrabold mb-5 leading-tight">
          Готові побачити<br/>
          <span class="bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">Karting Manager у дії?</span>
        </h2>
        <p class="text-slate-400 text-lg mb-8 leading-relaxed">
          Залиште контакти — проведемо персональне демо, відповімо на питання та допоможемо підібрати тариф.
        </p>

        <!-- Benefits -->
        <ul class="space-y-3">
          {[
            'Демо без зобов\'язань — безкоштовно',
            'Відповімо протягом 2 годин',
            'Налаштування та онбординг входить у ціну',
          ].map((item) => (
            <li class="flex items-center gap-3 text-sm text-slate-400">
              <svg class="w-4 h-4 text-indigo-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: form -->
      <div>
        <form
          class="bg-white/[0.04] border border-white/10 rounded-2xl p-7 space-y-5 backdrop-blur-sm"
          id="contact-form"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2" for="name">Ім'я</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Олексій"
                class="w-full bg-slate-900/80 border border-white/10 focus:border-indigo-500/60 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none transition-colors duration-200 text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-300 mb-2" for="phone">Телефон</label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                placeholder="+38 (067) 000-00-00"
                class="w-full bg-slate-900/80 border border-white/10 focus:border-indigo-500/60 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none transition-colors duration-200 text-sm"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2" for="club">Назва клубу</label>
            <input
              id="club"
              name="club"
              type="text"
              placeholder="Картинг Арена"
              class="w-full bg-slate-900/80 border border-white/10 focus:border-indigo-500/60 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none transition-colors duration-200 text-sm"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2" for="message">Повідомлення</label>
            <textarea
              id="message"
              name="message"
              rows="3"
              placeholder="Розкажіть про ваш клуб і що вас цікавить..."
              class="w-full bg-slate-900/80 border border-white/10 focus:border-indigo-500/60 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none transition-colors duration-200 resize-none text-sm"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3.5 rounded-xl transition-all duration-200 text-base shadow-lg shadow-indigo-600/20 hover:shadow-indigo-500/30 cursor-pointer"
          >
            Отримати безкоштовне демо
          </button>

          <p id="form-status" class="text-center text-sm hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    status.textContent = 'Надсилаємо...';
    status.className = 'text-center text-sm text-slate-400';
    status.classList.remove('hidden');

    await new Promise((r) => setTimeout(r, 800));

    status.textContent = 'Заявку отримано! Зв\'яжемося з вами найближчим часом.';
    status.className = 'text-center text-sm text-indigo-400';
    form.reset();
  });
</script>
