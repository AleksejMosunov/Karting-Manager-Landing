---
const features = [
  {
    title: 'Бронювання трас',
    description: 'Інтерактивний календар з відображенням доступних слотів у реальному часі. Менеджери бачать все на одному екрані.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'POS-каса',
    description: 'Повноцінна каса з підтримкою Checkbox для фіскалізації. Оплата карткою через хмарний POS-термінал прямо з інтерфейсу.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
  },
  {
    title: 'Бонусна програма',
    description: 'Нарахування та списання бонусів, інтеграція з Poster POS. Клієнти накопичують бали та витрачають їх на майбутні поїздки.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  },
  {
    title: 'Аналітика',
    description: 'Дашборд із ключовими метриками: виручка, популярні слоти, активність клієнтів. Фільтри по датах та локаціях.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  },
  {
    title: 'Мобільний застосунок',
    description: 'Клієнти бронюють траси, перевіряють баланс бонусів та отримують push-сповіщення через мобільний застосунок.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  },
  {
    title: 'Подарункові сертифікати',
    description: 'Генерація та продаж сертифікатів з QR-кодом. Сканування прямо на касі — без зайвих кроків.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>`,
  },
  {
    title: 'Мультилокаційність',
    description: 'Керуйте кількома клубами з одного облікового запису. Кожна локація має власні траси, розклад та команду.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
  },
  {
    title: 'Сповіщення',
    description: 'Telegram-сповіщення для адміністраторів та push-сповіщення для клієнтів. Важливі події — одразу в телефоні.',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>`,
  },
];
---

<section id="features" class="pt-10 pb-10 bg-slate-900 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_100%,rgba(99,102,241,0.08),transparent)]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-5">
        <span class="text-slate-400 text-sm font-medium">Можливості платформи</span>
      </div>
      <h2 class="text-4xl sm:text-5xl font-extrabold mb-4">
        Всі інструменти <span class="bg-gradient-to-r from-indigo-400 to-cyan-400 bg-clip-text text-transparent">в одному місці</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto">
        Karting Manager закриває весь операційний цикл клубу — від бронювання до фіскального чека.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {features.map((feature, i) => (
        <div class="group bg-white/[0.04] hover:bg-white/[0.07] border border-white/10 hover:border-indigo-500/40 rounded-2xl p-6 transition-all duration-300 cursor-default" data-animate="fade-up" data-animate-delay={(i % 4) + 1}>
          <div class="w-10 h-10 bg-indigo-600/20 rounded-xl flex items-center justify-center text-indigo-400 mb-4 group-hover:bg-indigo-600/30 transition-colors duration-300" set:html={feature.icon} />
          <h3 class="text-base font-semibold mb-2 text-white group-hover:text-indigo-300 transition-colors duration-200">{feature.title}</h3>
          <p class="text-slate-500 text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
